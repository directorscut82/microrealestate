{
  "name": "@microrealestate/emailer",
  "version": "1.0.0",
  "description": "Generates and sends emails",
  "main": "./dist/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean:types": "rimraf ../../types/dist",
    "clean:common": "rimraf ../common/dist",
    "clean:service": "rimraf dist",
    "clean": "npm-run-all clean:types clean:common clean:service",
    "transpile:types": "tsc --build ../../types/tsconfig.json",
    "transpile:common": "tsc --build ../common/tsconfig.json",
    "transpile:service": "tsc",
    "copy:assets": "cp -r src/locales dist/locales && cp -r src/emailparts/contents dist/emailparts/contents",
    "transpile": "npm-run-all transpile:types transpile:common transpile:service copy:assets",
    "build": "npm-run-all clean transpile",
    "watch:types": "tsc --build ../../types/tsconfig.json --watch --preserveWatchOutput",
    "watch:common": "tsc --build ../common/tsconfig.json --watch --preserveWatchOutput",
    "watch:service": "tsx --watch src/index.ts --watch-preserve-output --inspect=0.0.0.0:9228",
    "start": "node dist/index.js",
    "dev": "npm-run-all build --parallel watch:types watch:common watch:service",
    "eslint": "eslint .",
    "lint": "npm-run-all transpile eslint",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,css}'"
  },
  "keywords": [
    "email",
    "gmail",
    "mailgun"
  ],
  "author": "Camel Aissani",
  "license": "MIT",
  "dependencies": {
    "@microrealestate/common": "*",
    "axios": "1.8.4",
    "ejs": "3.1.10",
    "i18n": "0.14.2",
    "jsonwebtoken": "9.0.0",
    "locale": "0.1.0",
    "moment": "2.29.4",
    "nodemailer": "6.9.14",
    "nodemailer-mailgun-transport": "2.1.5"
  },
  "devDependencies": {
    "@microrealestate/types": "*",
    "@typescript-eslint/eslint-plugin": "7.15.0",
    "@typescript-eslint/parser": "7.15.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.29.1",
    "npm-run-all": "4.1.5",
    "rimraf": "6.0.1",
    "tsx": "3.14.0",
    "typescript": "5.5.4"
  }
}
