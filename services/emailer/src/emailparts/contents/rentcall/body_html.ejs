<!doctype html>
<html>
  <%- include('../__content_parts/html/htmlhead.ejs') %>
  <body>
    <div class="email-body">
      <div class="email-container">
        <div class="bar"></div>
        <div class="content">
          <div class="header">
            <div class="logo"><%-landlord.name%></div>
          </div>
          <div class="title"><%- _.t('Payment notice') %></div>
          <p><%- include('../__content_parts/html/greetings.ejs') %></p>
          <p>
            <%- _.t('Please find in attachment the rent notice of <strong>{{term}}</strong>.', { term: _.formatTerm(period, tenant.contract.lease.timeRange) }) %>
          </p>
          <p>
            <%- _.t('The amount of your rent is <strong>{{amount}}</strong>.', { amount: _.formatNumber(tenant.rents[0].total.grandTotal, 'currency') }) %>
          </p>
          <% var rent = tenant.rents[0]; %>
          <% if ((rent.buildingCharges && rent.buildingCharges.length) || (rent.preTaxAmounts && rent.preTaxAmounts.length > 1) || (rent.charges && rent.charges.length)) { %>
          <table style="border-collapse:collapse;width:100%;margin:10px 0;">
            <% rent.preTaxAmounts.forEach(function(item) { %>
            <tr><td style="padding:4px 8px;border-bottom:1px solid #eee;"><%- item.description %></td><td style="padding:4px 8px;border-bottom:1px solid #eee;text-align:right;"><%- _.formatNumber(item.amount, 'currency') %></td></tr>
            <% }); %>
            <% (rent.charges || []).forEach(function(item) { %>
            <tr><td style="padding:4px 8px;border-bottom:1px solid #eee;"><%- item.description %></td><td style="padding:4px 8px;border-bottom:1px solid #eee;text-align:right;"><%- _.formatNumber(item.amount, 'currency') %></td></tr>
            <% }); %>
            <% (rent.buildingCharges || []).forEach(function(item) { %>
            <tr><td style="padding:4px 8px;border-bottom:1px solid #eee;"><%- item.buildingName ? item.buildingName + ' - ' : '' %><%- item.description %></td><td style="padding:4px 8px;border-bottom:1px solid #eee;text-align:right;"><%- _.formatNumber(item.amount, 'currency') %></td></tr>
            <% }); %>
            <tr><td style="padding:4px 8px;font-weight:bold;"><strong><%- _.t('Total') %></strong></td><td style="padding:4px 8px;text-align:right;font-weight:bold;"><strong><%- _.formatNumber(rent.total.grandTotal, 'currency') %></strong></td></tr>
          </table>
          <% } %>
          <p>
            <%- _.t('Please send us your payment before <strong>{{date}}</strong>.', { date: _.formatDate(dueDate, 'LL') }) %>
          </p>
          <%- include('../__content_parts/html/paymentmethods.ejs') %>         
          <p>
            <%- _.t('We are at your service for any further information you may need.') %>
          </p>
          <%- include('../__content_parts/html/signature.ejs') %>   
        </div>
      </div>
      <%- include('../__content_parts/html/landlordcontact.ejs') %>   
    </div>
  </body>
</html>
