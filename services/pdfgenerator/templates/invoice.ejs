<!DOCTYPE html>
<html>
<%- include('/partials/htmlhead.ejs') %>

	<body>
		<% tenant.rents.forEach(function(rent) { %>
			<div class="page invoice">
				<%- include('partials/header.ejs') %>

					<%- include('partials/customeraddress.ejs') %>

						<%- include('partials/placeanddate.ejs', {rent: rent}) %>

							<div class="title">
								<%=_.t('Receipt')%>
							</div>

							<%- include('partials/customerreference.ejs', { rent: rent, labelKey: 'Receipt number' }) %>

								<div class="items">
									<table>
										<%- include('partials/invoicebody.ejs', { rent: rent }) %>

											<%- include('partials/invoicetotal.ejs', { rent: rent }) %>
									</table>
								</div>
								<%- include('partials/footer.ejs') %>
			</div>
			<% }); %>
	</body>

</html>