{
	# Global options
	auto_https off
}

{$APP_PROTOCOL:http}://{$APP_DOMAIN}{$APP_PORT_LISTEN} {
	# --- Security headers (basic hardening) ---
	header {
		# Force HTTPS for 1 year for any client that connects over TLS
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Disallow framing (clickjacking protection)
		X-Frame-Options "DENY"
		# Disable MIME sniffing
		X-Content-Type-Options "nosniff"
		# Restrict referrer leakage
		Referrer-Policy "strict-origin-when-cross-origin"
		# Conservative permissions policy
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Basic CSP — Next.js needs 'unsafe-inline' / 'unsafe-eval' for hydration & styles
		Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self'; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		# Strip the leaky default
		-Server
	}

	reverse_proxy gateway:8080
}
